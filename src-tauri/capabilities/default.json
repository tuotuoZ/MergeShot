{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for MergeShot",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-execute",
    "shell:allow-open",
    "shell:allow-stdin-write",
    "shell:allow-kill",
    "dialog:allow-open",
    "dialog:allow-save",
    "dialog:allow-message",
    "dialog:allow-ask",
    "fs:read-all",
    "fs:allow-write",
    "fs:read-meta",
    "fs:allow-exists",
    "fs:allow-mkdir",
    "opener:allow-open-path",
    "opener:allow-reveal-item-in-dir"
  ]
}
